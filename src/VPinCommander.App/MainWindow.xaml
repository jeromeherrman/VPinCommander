<Window x:Class="VPinCommander.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VPin Commander"
        Width="1180" Height="760"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <Style x:Key="MainTab" TargetType="TabItem">
      <Setter Property="Padding" Value="18,8" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </Window.Resources>

  <TabControl BorderThickness="0" Background="Transparent">
    <TabItem Header="My Cabinet" Style="{StaticResource MainTab}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="200" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E2E">
          <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Text="VPin Commander"
                       Foreground="#F0C040"
                       FontSize="18" FontWeight="Bold"
                       Margin="16,20,16,24" />
            <ListBox ItemsSource="{Binding Pages}"
                     SelectedItem="{Binding CurrentPage, Mode=TwoWay}"
                     Background="Transparent" BorderThickness="0">
              <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                  <Setter Property="Foreground" Value="#D0D0DC" />
                  <Setter Property="Padding" Value="16,10" />
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                          <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#33406080" />
                            <Setter Property="Foreground" Value="White" />
                          </Trigger>
                          <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#22406080" />
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </ListBox.ItemContainerStyle>
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Title}" FontSize="14" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </DockPanel>
        </Border>

        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" Margin="24" />
      </Grid>
    </TabItem>

    <TabItem Header="Downloads" Style="{StaticResource MainTab}">
      <TabControl Margin="16" BorderThickness="0,1,0,0" BorderBrush="#DDD">
        <TabItem Header="New table versions" Padding="14,6">
          <ContentControl Content="{Binding Updates}" Margin="8,16,8,8" />
        </TabItem>
        <TabItem Header="Install downloaded content" Padding="14,6">
          <ContentControl Content="{Binding Installer}" Margin="8,16,8,8" />
        </TabItem>
      </TabControl>
    </TabItem>

    <TabItem Header="Remote Cabinets" Style="{StaticResource MainTab}">
      <ContentControl Content="{Binding Cabinets}" Margin="24" />
    </TabItem>
  </TabControl>
</Window>
