<UserControl x:Class="VPinCommander.App.Views.TablesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <DockPanel>
    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
      <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding RefreshCommand}" Padding="14,6" />
      <TextBlock Text="Tables" FontSize="24" FontWeight="SemiBold" />
    </DockPanel>

    <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Foreground="#666" Margin="0,8,0,0" />

    <DataGrid ItemsSource="{Binding Tables}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserAddRows="False"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
        <DataGridTextColumn Header="Format" Binding="{Binding Format}" Width="Auto" />
        <DataGridTextColumn Header="Size (bytes)" Binding="{Binding FileSizeBytes, StringFormat=N0}" Width="Auto" />
        <DataGridTextColumn Header="Modified (UTC)" Binding="{Binding FileModifiedUtc, StringFormat=g}" Width="Auto" />
        <DataGridCheckBoxColumn Header="Missing" Binding="{Binding IsMissing}" Width="Auto" />
        <DataGridTextColumn Header="Path" Binding="{Binding FilePath}" Width="3*" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</UserControl>
