<UserControl x:Class="VPinCommander.App.Views.InstallerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <DockPanel>
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
      <TextBlock Text="Installer" FontSize="24" FontWeight="SemiBold" />
      <TextBlock Foreground="#666" TextWrapping="Wrap" Margin="0,4,0,12"
                 Text="One-click install for content you downloaded: tables, backglasses, ROMs, PuP-Packs, DMD colorizations, AltSound, and media are recognized automatically and placed in the proper folders. Nothing is ever overwritten." />
      <StackPanel Orientation="Horizontal">
        <Button Content="Add files…" Command="{Binding AddFilesCommand}" Padding="20,10" FontWeight="SemiBold" />
        <Button Content="Scan Downloads folder" Command="{Binding ScanDownloadsCommand}" Padding="14,10" Margin="12,0,0,0" />
        <Button Content="Install all" Command="{Binding InstallCommand}" Padding="20,10" Margin="24,0,0,0" FontWeight="SemiBold" />
        <Button Content="Clear" Command="{Binding ClearCommand}" Padding="14,10" Margin="12,0,0,0" />
      </StackPanel>
    </StackPanel>

    <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Foreground="#444" Margin="0,8,0,0" TextWrapping="Wrap" />

    <DataGrid ItemsSource="{Binding Items}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserAddRows="False"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column">
      <DataGrid.Columns>
        <DataGridTextColumn Header="File" Binding="{Binding FileName, Mode=OneWay}" Width="2*" />
        <DataGridTextColumn Header="Recognized as" Binding="{Binding Kind, Mode=OneWay}" Width="Auto" />
        <DataGridTextColumn Header="Details" Binding="{Binding Description, Mode=OneWay}" Width="2*" />
        <DataGridTextColumn Header="Target folder" Binding="{Binding TargetPath, Mode=OneWay}" Width="3*" />
        <DataGridTextColumn Header="Problem" Binding="{Binding Error, Mode=OneWay}" Width="2*" />
        <DataGridTextColumn Header="Result" Binding="{Binding Status, Mode=OneWay}" Width="2*" />
      </DataGrid.Columns>
      <DataGrid.RowStyle>
        <Style TargetType="DataGridRow">
          <Setter Property="Foreground" Value="#C0392B" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding Error}" Value="{x:Null}">
              <Setter Property="Foreground" Value="Black" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </DataGrid.RowStyle>
    </DataGrid>
  </DockPanel>
</UserControl>
