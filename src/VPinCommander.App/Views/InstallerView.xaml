<UserControl x:Class="VPinCommander.App.Views.InstallerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VPinCommander.App.Converters">
  <UserControl.Resources>
    <conv:ImagePreviewConverter x:Key="ImagePreview" />
  </UserControl.Resources>

  <DockPanel>
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
      <TextBlock Text="Installer" FontSize="24" FontWeight="SemiBold" />
      <TextBlock Foreground="#666" TextWrapping="Wrap" Margin="0,4,0,12"
                 Text="One-click install for content you downloaded: tables, backglasses, ROMs, PuP-Packs, DMD colorizations, AltSound, and media are recognized automatically and placed in the proper folders. Nothing is ever overwritten." />
      <StackPanel Orientation="Horizontal">
        <Button Content="Add files…" Command="{Binding AddFilesCommand}" Padding="20,10" FontWeight="SemiBold" />
        <Button Content="Scan Downloads folder" Command="{Binding ScanDownloadsCommand}" Padding="14,10" Margin="12,0,0,0" />
        <Button Content="Install all" Command="{Binding InstallCommand}" Padding="20,10" Margin="24,0,0,0" FontWeight="SemiBold" />
        <Button Content="Clear" Command="{Binding ClearCommand}" Padding="14,10" Margin="12,0,0,0" />
      </StackPanel>
    </StackPanel>

    <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Foreground="#444" Margin="0,8,0,0" TextWrapping="Wrap" />

    <Border DockPanel.Dock="Right" Width="320" Margin="16,0,0,0"
            Background="#F4F4F8" CornerRadius="8" Padding="12">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Preview" FontWeight="SemiBold" Margin="0,0,0,8" />
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding PreviewNote}" Foreground="#666" FontSize="11"
                   TextWrapping="Wrap" Margin="0,8,0,0" />

        <ListBox DockPanel.Dock="Bottom" MaxHeight="140" Margin="0,8,0,0"
                 ItemsSource="{Binding PreviewEntries}"
                 SelectedItem="{Binding SelectedPreviewEntry, Mode=TwoWay}"
                 DisplayMemberPath="DisplayName" FontSize="11">
          <ListBox.Style>
            <Style TargetType="ListBox">
              <Style.Triggers>
                <Trigger Property="HasItems" Value="False">
                  <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
              </Style.Triggers>
            </Style>
          </ListBox.Style>
        </ListBox>

        <Grid>
          <Border Background="#22000000" CornerRadius="4" MinHeight="200">
            <Grid>
              <Image Source="{Binding PreviewImagePath, Converter={StaticResource ImagePreview}}"
                     Stretch="Uniform">
                <Image.Style>
                  <Style TargetType="Image">
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding PreviewImagePath}" Value="{x:Null}">
                        <Setter Property="Visibility" Value="Collapsed" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Image.Style>
              </Image>

              <DockPanel>
                <DockPanel.Style>
                  <Style TargetType="DockPanel">
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding PreviewMediaPath}" Value="{x:Null}">
                        <Setter Property="Visibility" Value="Collapsed" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </DockPanel.Style>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6">
                  <Button Content="▶ Play" Click="PlayPreview_Click" Padding="12,4" />
                  <Button Content="■ Stop" Click="StopPreview_Click" Padding="12,4" Margin="8,0,0,0" />
                  <TextBlock x:Name="PlayerStatus" VerticalAlignment="Center" Margin="10,0,0,0"
                             Foreground="#C0392B" FontSize="11" />
                </StackPanel>
                <MediaElement x:Name="PreviewPlayer"
                              Source="{Binding PreviewMediaPath}"
                              LoadedBehavior="Manual" UnloadedBehavior="Stop"
                              MediaFailed="PreviewPlayer_MediaFailed"
                              MediaOpened="PreviewPlayer_MediaOpened"
                              Stretch="Uniform" />
              </DockPanel>
            </Grid>
          </Border>
        </Grid>
      </DockPanel>
    </Border>

    <DataGrid ItemsSource="{Binding Items}"
              SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserAddRows="False"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column">
      <DataGrid.Columns>
        <DataGridTextColumn Header="File" Binding="{Binding FileName, Mode=OneWay}" Width="2*" />
        <DataGridTextColumn Header="Recognized as" Binding="{Binding Kind, Mode=OneWay}" Width="Auto" />
        <DataGridTextColumn Header="Details" Binding="{Binding Description, Mode=OneWay}" Width="2*" />
        <DataGridTextColumn Header="Target folder" Binding="{Binding TargetPath, Mode=OneWay}" Width="3*" />
        <DataGridTextColumn Header="Problem" Binding="{Binding Error, Mode=OneWay}" Width="2*" />
        <DataGridTextColumn Header="Result" Binding="{Binding Status, Mode=OneWay}" Width="2*" />
      </DataGrid.Columns>
      <DataGrid.RowStyle>
        <Style TargetType="DataGridRow">
          <Setter Property="Foreground" Value="#C0392B" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding Error}" Value="{x:Null}">
              <Setter Property="Foreground" Value="Black" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </DataGrid.RowStyle>
    </DataGrid>
  </DockPanel>
</UserControl>
