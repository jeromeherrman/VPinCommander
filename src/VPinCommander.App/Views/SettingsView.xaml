<UserControl x:Class="VPinCommander.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <Style x:Key="FolderBox" TargetType="TextBox">
      <Setter Property="AcceptsReturn" Value="True" />
      <Setter Property="MinHeight" Value="64" />
      <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
      <Setter Property="FontFamily" Value="Consolas" />
      <Setter Property="Margin" Value="0,4,0,16" />
      <Setter Property="Padding" Value="6" />
    </Style>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel MaxWidth="720" HorizontalAlignment="Left">
      <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8" />
      <TextBlock Text="One folder per line. Subfolders are scanned automatically."
                 Foreground="#666" Margin="0,0,0,20" />

      <TextBlock Text="Table folders (.vpx, .fp)" FontWeight="SemiBold" />
      <TextBox Style="{StaticResource FolderBox}"
               Text="{Binding TableFoldersText, UpdateSourceTrigger=PropertyChanged}" />

      <TextBlock Text="ROM folders (.zip)" FontWeight="SemiBold" />
      <TextBox Style="{StaticResource FolderBox}"
               Text="{Binding RomFoldersText, UpdateSourceTrigger=PropertyChanged}" />

      <TextBlock Text="Media folders (images, video, audio)" FontWeight="SemiBold" />
      <TextBox Style="{StaticResource FolderBox}"
               Text="{Binding MediaFoldersText, UpdateSourceTrigger=PropertyChanged}" />

      <TextBlock Text="PinUP Popper system folder" FontWeight="SemiBold" />
      <TextBlock Text="Folder containing PUPDatabase.db (e.g. C:\vPinball\PinUPSystem). Leave empty to auto-detect."
                 Foreground="#666" FontSize="12" Margin="0,2,0,0" />
      <TextBox FontFamily="Consolas" Padding="6" Margin="0,4,0,16"
               Text="{Binding PinUpFolderText, UpdateSourceTrigger=PropertyChanged}" />

      <TextBlock Text="PinballX install folder" FontWeight="SemiBold" />
      <TextBlock Text="Folder containing Databases\ and Config\PinballX.ini (e.g. C:\PinballX). Leave empty to auto-detect."
                 Foreground="#666" FontSize="12" Margin="0,2,0,0" />
      <TextBox FontFamily="Consolas" Padding="6" Margin="0,4,0,16"
               Text="{Binding PinballXFolderText, UpdateSourceTrigger=PropertyChanged}" />

      <TextBlock Text="PinballY install folder" FontWeight="SemiBold" />
      <TextBlock Text="Folder containing Databases\ and Settings.txt (e.g. C:\PinballY). Leave empty to auto-detect."
                 Foreground="#666" FontSize="12" Margin="0,2,0,0" />
      <TextBox FontFamily="Consolas" Padding="6" Margin="0,4,0,16"
               Text="{Binding PinballYFolderText, UpdateSourceTrigger=PropertyChanged}" />

      <TextBlock Text="DOF config folder" FontWeight="SemiBold" />
      <TextBlock Text="Folder containing directoutputconfig*.ini from the DOF Config Tool (e.g. C:\DirectOutput). Leave empty to auto-detect."
                 Foreground="#666" FontSize="12" Margin="0,2,0,0" />
      <TextBox FontFamily="Consolas" Padding="6" Margin="0,4,0,16"
               Text="{Binding DofFolderText, UpdateSourceTrigger=PropertyChanged}" />

      <StackPanel Orientation="Horizontal">
        <Button Content="Save settings" Command="{Binding SaveCommand}" Padding="20,10" FontWeight="SemiBold" />
        <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="#2E7D32" />
      </StackPanel>

      <TextBlock Text="Downloads folder to monitor" FontWeight="SemiBold" />
      <TextBlock Text="The Installer watches this folder for new tables and media and adds them automatically. Leave empty to use your Windows Downloads folder."
                 Foreground="#666" FontSize="12" Margin="0,2,0,0" />
      <TextBox FontFamily="Consolas" Padding="6" Margin="0,4,0,16"
               Text="{Binding DownloadsFolderText, UpdateSourceTrigger=PropertyChanged}" />

      <TextBlock Text="Backup &amp; restore" FontWeight="SemiBold" FontSize="16" Margin="0,32,0,4" />
      <TextBlock Text="Backs up the inventory database and these settings into a single zip. Restoring replaces both and restarts the app; a .pre-restore copy of the database is kept."
                 Foreground="#666" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8" />
      <StackPanel Orientation="Horizontal">
        <Button Content="Create backup…" Command="{Binding BackupCommand}" Padding="14,8" />
        <Button Content="Restore backup…" Command="{Binding RestoreCommand}" Padding="14,8" Margin="12,0,0,0" />
      </StackPanel>

      <TextBlock Text="Cloud synchronization (optional)" FontWeight="SemiBold" FontSize="16" Margin="0,32,0,4" />
      <TextBlock Text="Point this at any folder your cloud client already syncs (OneDrive, Dropbox, Google Drive). Push writes the database + settings there; Pull restores them on another machine. Save settings after changing the folder."
                 Foreground="#666" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,6" />
      <TextBox FontFamily="Consolas" Padding="6" Margin="0,4,0,8"
               Text="{Binding CloudFolderText, UpdateSourceTrigger=PropertyChanged}" />
      <StackPanel Orientation="Horizontal">
        <Button Content="Push to cloud" Command="{Binding CloudPushCommand}" Padding="14,8" />
        <Button Content="Pull from cloud…" Command="{Binding CloudPullCommand}" Padding="14,8" Margin="12,0,0,0" />
        <TextBlock Text="{Binding CloudStatusText}" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="#666" />
      </StackPanel>

      <TextBlock Text="Remote-control server (cabinet mode)" FontWeight="SemiBold" FontSize="16" Margin="0,32,0,4" />
      <TextBlock Text="Run this on the cabinet so other VPin Commander instances can manage it from the Remote Cabinets tab. Plain HTTP on your LAN, protected by the API key — if clients cannot connect, allow VPin Commander through Windows Firewall."
                 Foreground="#666" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8" />
      <CheckBox Content="Enable the server on this machine"
                IsChecked="{Binding ServerEnabled, Mode=TwoWay}" Margin="0,0,0,6" />
      <CheckBox Content="Use HTTPS (self-signed — recommended when cabinets are reachable beyond your home LAN)"
                IsChecked="{Binding ServerUseHttps, Mode=TwoWay}" Margin="0,0,0,8" />
      <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
        <TextBlock Text="Port:" VerticalAlignment="Center" Foreground="#666" />
        <TextBox Text="{Binding ServerPortText, UpdateSourceTrigger=PropertyChanged}"
                 Width="70" Padding="4" Margin="8,0,0,0" FontFamily="Consolas" />
        <TextBlock Text="{Binding ServerStatusText}" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="#666" FontSize="12" />
      </StackPanel>
      <TextBlock Text="API key (paste this into the client's Remote Cabinets tab)" Foreground="#666" FontSize="12" />
      <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
        <TextBox Text="{Binding ServerApiKeyText, UpdateSourceTrigger=PropertyChanged}"
                 Width="330" Padding="6" FontFamily="Consolas" />
        <Button Content="Generate new key" Command="{Binding GenerateApiKeyCommand}" Padding="12,6" Margin="10,0,0,0" />
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
