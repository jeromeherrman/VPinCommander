<UserControl x:Class="VPinCommander.App.Views.RomsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <DockPanel>
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
      <TextBlock Text="ROMs" FontSize="24" FontWeight="SemiBold" />
      <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
        <TextBlock Text="Show:" VerticalAlignment="Center" Foreground="#666" Margin="0,0,8,0" />
        <ComboBox ItemsSource="{Binding FilterOptions}"
                  SelectedItem="{Binding SelectedFilter, Mode=TwoWay}"
                  MinWidth="140" VerticalAlignment="Center" />
        <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="14,6" Margin="20,0,0,0" />
        <Button Content="Quarantine selected" Command="{Binding QuarantineCommand}"
                Padding="14,6" Margin="12,0,0,0" />
      </StackPanel>
    </StackPanel>

    <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Foreground="#444" Margin="0,8,0,0" TextWrapping="Wrap" />

    <DataGrid ItemsSource="{Binding Rows}"
              SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserAddRows="False"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column">
      <DataGrid.Columns>
        <DataGridTextColumn Header="ROM" Binding="{Binding Name}" Width="*" />
        <DataGridTextColumn Header="Referenced by" Binding="{Binding ReferenceCount}" Width="Auto" />
        <DataGridTextColumn Header="Copies" Binding="{Binding CopyCount}" Width="Auto" />
        <!-- Explicit OneWay: the default TwoWay crashes on RomRow's read-only property. -->
        <DataGridCheckBoxColumn Header="Missing" Binding="{Binding IsMissing, Mode=OneWay}" Width="Auto" />
        <DataGridTextColumn Header="Size (bytes)" Binding="{Binding FileSizeBytes, StringFormat=N0}" Width="Auto" />
        <DataGridTextColumn Header="Path" Binding="{Binding FilePath}" Width="3*" />
      </DataGrid.Columns>
      <DataGrid.RowStyle>
        <Style TargetType="DataGridRow">
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsDuplicate}" Value="True">
              <Setter Property="Foreground" Value="#B9770E" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsMissing}" Value="True">
              <Setter Property="Foreground" Value="#C0392B" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </DataGrid.RowStyle>
    </DataGrid>
  </DockPanel>
</UserControl>
