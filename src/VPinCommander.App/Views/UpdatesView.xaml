<UserControl x:Class="VPinCommander.App.Views.UpdatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <DockPanel>
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
      <TextBlock Text="Updates" FontSize="24" FontWeight="SemiBold" />
      <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
        <Button Content="Check for updates" Command="{Binding CheckCommand}"
                Padding="20,10" FontWeight="SemiBold" />
        <Button Content="Browse all tables" Command="{Binding BrowseAllCommand}"
                Padding="20,10" Margin="12,0,0,0" FontWeight="SemiBold" />
        <Button Content="Refresh catalog &amp; check" Command="{Binding ForceCheckCommand}"
                Padding="14,10" Margin="12,0,0,0" />
        <Button Content="Open download page" Command="{Binding OpenLinkCommand}"
                Padding="14,10" Margin="12,0,0,0" />
        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 MinWidth="220" Padding="6" Margin="24,0,0,0" VerticalAlignment="Center"
                 ToolTip="Search by table name" />
      </StackPanel>
    </StackPanel>

    <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Foreground="#444" Margin="0,8,0,0" TextWrapping="Wrap" />

    <Border DockPanel.Dock="Right" Width="300" Margin="16,0,0,0"
            Background="#F4F4F8" CornerRadius="8" Padding="12">
      <StackPanel>
        <TextBlock Text="Preview" FontWeight="SemiBold" Margin="0,0,0,8" />
        <Border Height="210" Background="#22000000" CornerRadius="4">
          <Grid>
            <TextBlock Text="Select an update to preview it."
                       Foreground="#888" FontSize="11" TextWrapping="Wrap"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding SelectedUpdate}" Value="{x:Null}">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
            <Image Source="{Binding SelectedUpdate.ImageUrl, IsAsync=True, TargetNullValue={x:Null}}"
                   Stretch="Uniform" Margin="4" />
          </Grid>
        </Border>
        <TextBlock Text="{Binding SelectedUpdate.TableName}" FontWeight="SemiBold"
                   TextWrapping="Wrap" Margin="0,10,0,2" />
        <TextBlock Foreground="#666" FontSize="12">
          <Run Text="Installed:" /><Run Text="{Binding SelectedUpdate.LocalVersion, Mode=OneWay}" />
          <Run Text="  →  Latest:" /><Run Text="{Binding SelectedUpdate.RemoteVersion, Mode=OneWay}" />
        </TextBlock>
        <TextBlock Foreground="#666" FontSize="12" Margin="0,2,0,10">
          <Run Text="Released:" /><Run Text="{Binding SelectedUpdate.RemoteUpdatedUtc, Mode=OneWay, StringFormat=g}" />
        </TextBlock>
        <Button Content="Open download page" Command="{Binding OpenLinkCommand}"
                Padding="14,8" HorizontalAlignment="Left" />
      </StackPanel>
    </Border>

    <DataGrid ItemsSource="{Binding Updates}"
              SelectedItem="{Binding SelectedUpdate, Mode=TwoWay}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserAddRows="False"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column">
      <DataGrid.Columns>
        <DataGridTemplateColumn Header="Preview" Width="96" IsReadOnly="True">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <Border Height="54" Width="88" Background="#11000000" CornerRadius="3" Margin="2">
                <!-- WPF fetches web images asynchronously; a broken URL just leaves the placeholder. -->
                <Image Source="{Binding ImageUrl, IsAsync=True, TargetNullValue={x:Null}}"
                       Stretch="UniformToFill" />
              </Border>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="Table" Binding="{Binding TableName}" Width="2*" />
        <DataGridTextColumn Header="Installed" Binding="{Binding LocalVersion}" Width="Auto" />
        <DataGridTextColumn Header="Latest (VPS)" Binding="{Binding RemoteVersion}" Width="Auto" />
        <DataGridTextColumn Header="Released (UTC)" Binding="{Binding RemoteUpdatedUtc, StringFormat=g}" Width="Auto" />
        <DataGridTextColumn Header="Download page" Binding="{Binding Url}" Width="3*" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</UserControl>
