<UserControl x:Class="VPinCommander.App.Views.CabinetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="290" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="#F4F4F8" CornerRadius="8" Padding="12" Margin="0,0,16,0">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Cabinets" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />

        <StackPanel DockPanel.Dock="Bottom">
          <TextBlock Text="Add a cabinet" FontWeight="SemiBold" Margin="0,12,0,4" />
          <TextBlock Text="Name" Foreground="#666" FontSize="11" />
          <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Padding="4" Margin="0,2,0,6" />
          <TextBlock Text="Address (http://cabinet-pc:5588)" Foreground="#666" FontSize="11" />
          <TextBox Text="{Binding NewUrl, UpdateSourceTrigger=PropertyChanged}" Padding="4" Margin="0,2,0,6" FontFamily="Consolas" />
          <TextBlock Text="API key (from the cabinet's Settings page)" Foreground="#666" FontSize="11" />
          <TextBox Text="{Binding NewApiKey, UpdateSourceTrigger=PropertyChanged}" Padding="4" Margin="0,2,0,8" FontFamily="Consolas" />
          <StackPanel Orientation="Horizontal">
            <Button Content="Add" Command="{Binding AddCommand}" Padding="16,6" FontWeight="SemiBold" />
            <Button Content="Remove selected" Command="{Binding RemoveCommand}" Padding="12,6" Margin="10,0,0,0" />
          </StackPanel>
        </StackPanel>

        <ListBox ItemsSource="{Binding Cabinets}"
                 SelectedItem="{Binding SelectedCabinet, Mode=TwoWay}"
                 BorderThickness="0" Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="2,6">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding BaseUrl}" Foreground="#666" FontSize="11" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <DockPanel Grid.Column="1">
      <StackPanel DockPanel.Dock="Top">
        <TextBlock Text="Remote cabinet" FontSize="24" FontWeight="SemiBold" />
        <TextBlock Text="{Binding RemoteSummary}" Foreground="#444" TextWrapping="Wrap" Margin="0,8,0,12" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
          <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="16,8" FontWeight="SemiBold" />
          <Button Content="Run scan" Command="{Binding RunScanCommand}" Padding="16,8" Margin="12,0,0,0" />
          <TextBlock Text="Import:" VerticalAlignment="Center" Margin="24,0,8,0" Foreground="#666" />
          <ComboBox ItemsSource="{Binding ImportSources}"
                    SelectedItem="{Binding SelectedImportSource, Mode=TwoWay}"
                    MinWidth="110" VerticalAlignment="Center" />
          <Button Content="Import" Command="{Binding ImportCommand}" Padding="12,8" Margin="8,0,0,0" />
          <Button Content="Push content…" Command="{Binding PushContentCommand}"
                  Padding="16,8" Margin="24,0,0,0" FontWeight="SemiBold" />
        </StackPanel>
        <ListBox ItemsSource="{Binding PushLog}" MaxHeight="90" FontSize="11" Margin="0,0,0,10"
                 BorderBrush="#DDD">
          <ListBox.Style>
            <Style TargetType="ListBox">
              <Style.Triggers>
                <Trigger Property="HasItems" Value="False">
                  <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
              </Style.Triggers>
            </Style>
          </ListBox.Style>
        </ListBox>
        <TextBlock Text="Health findings on the selected cabinet" FontWeight="SemiBold" Margin="0,4,0,6" />
      </StackPanel>

      <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Foreground="#444" Margin="0,8,0,0" TextWrapping="Wrap" />

      <DataGrid ItemsSource="{Binding RemoteFindings}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                CanUserAddRows="False"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="Auto" />
          <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="Auto" />
          <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="*" />
          <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="3*" />
        </DataGrid.Columns>
        <DataGrid.RowStyle>
          <Style TargetType="DataGridRow">
            <Style.Triggers>
              <DataTrigger Binding="{Binding Severity}" Value="Error">
                <Setter Property="Foreground" Value="#C0392B" />
              </DataTrigger>
              <DataTrigger Binding="{Binding Severity}" Value="Warning">
                <Setter Property="Foreground" Value="#B9770E" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </DataGrid.RowStyle>
      </DataGrid>
    </DockPanel>
  </Grid>
</UserControl>
