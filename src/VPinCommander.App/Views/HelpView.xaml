<UserControl x:Class="VPinCommander.App.Views.HelpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:help="clr-namespace:VPinCommander.Core.Help;assembly=VPinCommander.Core">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="240" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <DockPanel Grid.Column="0" Margin="0,0,16,0">
      <TextBlock DockPanel.Dock="Top" Text="Help" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,12" />
      <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
        <Button Content="Full user guide (online)" Command="{Binding OpenUserGuideCommand}" Padding="10,8" HorizontalAlignment="Stretch" />
        <Button Content="Report an issue" Command="{Binding ReportIssueCommand}" Padding="10,8" Margin="0,8,0,0" HorizontalAlignment="Stretch" />
      </StackPanel>
      <ListBox ItemsSource="{Binding Topics}"
               SelectedItem="{Binding SelectedTopic, Mode=TwoWay}"
               BorderThickness="0" Background="#F4F4F8">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="{x:Type help:HelpTopic}">
            <TextBlock Text="{Binding Title}" Padding="6,8" TextWrapping="Wrap" FontSize="14" />
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </DockPanel>

    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
      <StackPanel MaxWidth="720" HorizontalAlignment="Left" Margin="0,4,0,0">
        <TextBlock Text="{Binding SelectedTopic.Title}" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12" />
        <ItemsControl ItemsSource="{Binding SelectedTopic.Blocks}">
          <ItemsControl.Resources>
            <!-- One template per block kind, chosen by the Kind value below. -->
          </ItemsControl.Resources>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type help:HelpBlock}">
              <ContentControl Content="{Binding}">
                <ContentControl.Style>
                  <Style TargetType="ContentControl">
                    <!-- Paragraph (default) -->
                    <Setter Property="ContentTemplate">
                      <Setter.Value>
                        <DataTemplate>
                          <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Margin="0,0,0,10" LineHeight="20" />
                        </DataTemplate>
                      </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding Kind}" Value="Heading">
                        <Setter Property="ContentTemplate">
                          <Setter.Value>
                            <DataTemplate>
                              <TextBlock Text="{Binding Text}" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,6" />
                            </DataTemplate>
                          </Setter.Value>
                        </Setter>
                      </DataTrigger>
                      <DataTrigger Binding="{Binding Kind}" Value="Bullet">
                        <Setter Property="ContentTemplate">
                          <Setter.Value>
                            <DataTemplate>
                              <Grid Margin="4,0,0,8">
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="16" />
                                  <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="•" Foreground="#406080" />
                                <TextBlock Grid.Column="1" Text="{Binding Text}" TextWrapping="Wrap" LineHeight="20" />
                              </Grid>
                            </DataTemplate>
                          </Setter.Value>
                        </Setter>
                      </DataTrigger>
                      <DataTrigger Binding="{Binding Kind}" Value="Tip">
                        <Setter Property="ContentTemplate">
                          <Setter.Value>
                            <DataTemplate>
                              <Border Background="#EEF4EC" BorderBrush="#C6DDBE" BorderThickness="1"
                                      CornerRadius="4" Padding="10,8" Margin="0,4,0,12">
                                <TextBlock TextWrapping="Wrap" LineHeight="20">
                                  <Run Text="Tip: " FontWeight="SemiBold" Foreground="#2E7D32" />
                                  <Run Text="{Binding Text, Mode=OneWay}" />
                                </TextBlock>
                              </Border>
                            </DataTemplate>
                          </Setter.Value>
                        </Setter>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </ContentControl.Style>
              </ContentControl>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
