<Application x:Class="VPinCommander.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VPinCommander.App.ViewModels"
             xmlns:views="clr-namespace:VPinCommander.App.Views"
             ShutdownMode="OnMainWindowClose">
  <Application.Resources>
    <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
      <views:DashboardView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:TablesViewModel}">
      <views:TablesView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:PopperViewModel}">
      <views:FrontEndView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:PinballXViewModel}">
      <views:FrontEndView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:HealthViewModel}">
      <views:HealthView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:MediaViewModel}">
      <views:MediaView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:RomsViewModel}">
      <views:RomsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:UpdatesViewModel}">
      <views:UpdatesView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
      <views:SettingsView />
    </DataTemplate>
  </Application.Resources>
</Application>
